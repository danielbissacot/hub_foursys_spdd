{
  "name": "agentes-foursys",
  "displayName": "Agentes Foursys - AI Governance Hub",
  "description": "Orquestrador dinâmico de engenharia de software baseado em Playbooks do catálogo AI Governance Hub.",
  "version": "1.0.1",
  "publisher": "foursys",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentes-foursys-sidebar",
          "title": "Agentes Foursys",
          "icon": "resources/logo.png"
        }
      ]
    },
    "views": {
      "agentes-foursys-sidebar": [
        {
          "type": "webview",
          "id": "agentes-foursys-sidebar-view",
          "name": "Agentes Foursys"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "agentes_foursys",
        "name": "agentes_foursys",
        "fullName": "Agentes Foursys",
        "description": "Assistente de Governança de IA para Playbooks de Engenharia.",
        "isDefault": false,
        "commands": [
          { "name": "refinar", "description": "Executa a Fase 1: Refinamento de Negócio" },
          { "name": "desenhar", "description": "Executa a Fase 2: Desenho Técnico" },
          { "name": "desenvolver", "description": "Executa a Fase de Codificação com Agente Especialista" },
          { "name": "review_angular", "description": "Executa Code Review para Angular" },
          { "name": "review_java", "description": "Executa Code Review para Java/Spring" },
          { "name": "teste_angular", "description": "Gera Testes Unitários para Angular" },
          { "name": "teste_java", "description": "Gera Testes Unitários para Java/Spring" }
        ]
      }
    ],
    "commands": [
      { "command": "playbook.connect", "title": "Playbook: Conectar Catálogo" },
      { "command": "playbook.insertStory", "title": "Playbook: Inserir História" },
      { "command": "playbook.validateStory", "title": "Playbook: Validação da História" },
      { "command": "playbook.technicalRules", "title": "Playbook: Regras Técnicas" },
      { "command": "playbook.develop", "title": "Playbook: Desenvolver" },
      { "command": "playbook.unitTests", "title": "Playbook: Testes Unitários" },
      { "command": "playbook.documentation", "title": "Playbook: Documentação" }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.96.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "@vscode/vsce": "^3.0.0"
  }
}
